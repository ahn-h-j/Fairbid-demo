<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    FairBid Checkstyle 가드레일.
    프로젝트 컨벤션에서 "절대 금지"인 것만 포함한다.
    스타일 취향(들여쓰기 등)은 포함하지 않는다.
-->
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="error"/>

    <module name="TreeWalker">

        <!-- @Autowired 필드 주입 금지: @RequiredArgsConstructor 생성자 주입만 사용 -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="NoAutowiredFieldInjection"/>
            <property name="format" value="@Autowired"/>
            <property name="message" value="@Autowired 필드 주입 금지. @RequiredArgsConstructor 생성자 주입을 사용하세요."/>
        </module>

        <!-- RuntimeException 직접 throw 금지: 커스텀 예외(DomainException 상속) 사용 -->
        <!-- TODO: 기존 RuntimeException 2건(RedisBidCacheAdapter, NotificationRedisAdapter)은 적절한 커스텀 예외 생성 후 제거 -->
        <!-- <module name="RegexpSinglelineJava">
            <property name="id" value="NoRawRuntimeException"/>
            <property name="format" value="throw\s+new\s+RuntimeException"/>
            <property name="message" value="RuntimeException 직접 throw 금지. DomainException을 상속한 커스텀 예외를 사용하세요."/>
        </module> -->

        <!-- System.out/err 사용 금지: 로거 사용 -->
        <module name="RegexpSinglelineJava">
            <property name="id" value="NoSystemOut"/>
            <property name="format" value="System\.(out|err)\.print"/>
            <property name="message" value="System.out/err 사용 금지. Logger를 사용하세요."/>
        </module>

        <!-- 와일드카드 import 금지: 명시적 import 사용 -->
        <module name="AvoidStarImport">
            <property name="allowStaticMemberImports" value="true"/>
        </module>

        <!-- 사용하지 않는 import 금지 -->
        <module name="UnusedImports"/>

    </module>
</module>
