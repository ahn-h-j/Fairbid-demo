# Anthropic Claude API key
CLAUDE_API_KEY=sk-ant-...

# Discord Bot token (대화형 비서 + 알람 발송)
# https://discord.com/developers/applications → Bot 생성 → Token 복사
# Bot 권한: Send Messages, Create Public Threads, Send Messages in Threads, Read Message History
DISCORD_BOT_TOKEN=MTA...

# 알람을 받을 Discord 채널 ID (우클릭 → 채널 ID 복사, 개발자 모드 필요)
DISCORD_CHANNEL_ID=1234567890

# Prometheus 주소 (docker-compose 내부에서는 prometheus:9090)
PROMETHEUS_URL=http://prometheus:9090

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
