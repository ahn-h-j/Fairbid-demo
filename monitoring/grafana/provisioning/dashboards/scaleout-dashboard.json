      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_sum{environment=\"scaleout\"}[1m]) / rate(http_server_requests_seconds_count{environment=\"scaleout\"}[1m])",
          "legendFormat": "avg {{method}} {{uri}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{environment=\"scaleout\"}[1m]))",
          "legendFormat": "p95 {{method}} {{uri}}",
          "refId": "B"
        }
      ],
      "title": "HTTP 응답 시간 (avg / p95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
